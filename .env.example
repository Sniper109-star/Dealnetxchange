# Example environment variables for Dealnetxchange
# Copy this file to `.env.local` and fill in real values for your environment.

# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Clerk (authentication) ----
# Get these from https://dashboard.clerk.com (API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Clerk routing (uses our custom /sign-in and /sign-up pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ---- Resend (transactional email) ----
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxx
# Verified sender address (Resend subdomain or your own domain)
EMAIL_FROM="Dealnetxchange <onboarding@resend.dev>"
EMAIL_REPLY_TO=support@dealnetxchange.com

# ---- Session secret (legacy placeholder, unused by Clerk) ----
SESSION_SECRET=change-me-to-a-long-random-string

# ---- Database (unused; in-memory store) ----
DATABASE_URL=
